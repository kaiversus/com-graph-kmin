# =====================================================================
# Neo4j connection — copy file này thành .env và sửa giá trị bên dưới
# .env KHÔNG nên commit vào git (chứa password).
# =====================================================================

# ---------------- Neo4j Aura (cloud) — DEFAULT ----------------
# URI lấy từ Aura console, dạng: neo4j+s://<id>.databases.neo4j.io
# Password chỉ hiện 1 lần lúc tạo instance, lưu trong file
# Neo4j-<id>-Created-<date>.txt mà Aura cấp.

NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=paste_your_aura_password_here
NEO4J_DATABASE=neo4j

# ---------------- Local Neo4j (Desktop / Docker) — alt ----------------
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_local_password
# NEO4J_DATABASE=neo4j

# ---------------- VPS / server riêng — alt ----------------
# NEO4J_URI=bolt://10.0.0.5:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=secret
# NEO4J_DATABASE=neo4j
